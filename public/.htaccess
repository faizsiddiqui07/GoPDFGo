<IfModule mod_rewrite.c>
  # Security aur Server ko confuse hone se bachane ke liye
  Options -Indexes -MultiViews
  RewriteEngine On

  # 1. Force Non-WWW
  RewriteCond %{HTTP_HOST} ^www\.gopdfgo\.com$ [NC]
  RewriteRule ^(.*)$ https://gopdfgo.com/$1 [L,R=301]

  # Ye rule URL mein slash hone ya na hone dono cases ko handle karega
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*?)/?$ $1.html [L]

  # 3. 404 Error Page
  ErrorDocument 404 /404.html
</IfModule>