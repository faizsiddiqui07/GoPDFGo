<IfModule mod_rewrite.c>
  Options -MultiViews
  RewriteEngine On
  RewriteBase /

  DirectoryIndex index.html

  # WWW → Non-WWW
  RewriteCond %{HTTP_HOST} ^www\.gopdfgo\.com$ [NC]
  RewriteRule ^(.*)$ https://gopdfgo.com/$1 [L,R=301]

  # Trailing Slash fix
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # ❗ IMPORTANT: 404 handling proper tarike se
  ErrorDocument 404 /404.html
</IfModule>